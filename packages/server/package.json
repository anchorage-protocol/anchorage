{
  "name": "@anchorage/server",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "description": "Anchorage MCP server: graph store, verification, governance machinery, identity. The trust boundary.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "start": "tsx src/index.ts",
    "live": "tsx --env-file-if-exists=../../.env --env-file-if-exists=.env src/run-live.ts",
    "population": "tsx --env-file-if-exists=../../.env --env-file-if-exists=.env src/run-population.ts",
    "deep-loop": "tsx --env-file-if-exists=../../.env --env-file-if-exists=.env src/run-deep-loop.ts",
    "deep-loop-cube": "tsx --env-file-if-exists=../../.env --env-file-if-exists=.env src/run-deep-loop-cube.ts"
  },
  "dependencies": {
    "@anchorage/contracts": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anchorage/testbed": "workspace:*"
  }
}
